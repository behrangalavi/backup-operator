# Copy this file to .env and adjust if needed. The Justfile loads `.env`
# automatically via `set dotenv-load`, so `just run` picks these up.

# --- Worker pod template ---
# The operator stamps these into every CronJob it produces. WORKER_IMAGE
# must be reachable from the cluster; for Docker Desktop the locally built
# `backup-operator:dev` tag is visible to the cluster as long as the pod
# does not try to pull (hence WORKER_IMAGE_PULL_POLICY=Never).
WORKER_IMAGE=backup-operator:dev
# Docker Desktop's K8s is kind under the hood: its node containerd is
# separate from the daemon's. With Never, kubelet would never try to
# pull and the image-mirror cannot bridge — IfNotPresent triggers the
# pull which the desktop-containerd-registry-mirror serves locally.
WORKER_IMAGE_PULL_POLICY=IfNotPresent
WORKER_SERVICE_ACCOUNT=backup-worker
AGE_SECRET_NAME=backup-operator-age

# --- Namespace scope ---
# Operator only watches Secrets in WATCH_NAMESPACE. POD_NAMESPACE is used
# for the leader-election lease (when LEADER_ELECTION_ID is set).
WATCH_NAMESPACE=backup
POD_NAMESPACE=backup

# --- UI (optional) ---
# Enable the built-in management dashboard. SETTINGS_CONFIGMAP must name
# an existing ConfigMap in the watch namespace (Helm creates it when
# ui.enabled=true; for `just run` you must create it manually).
# UI_ENABLED=true
# UI_ADDR=:8081
# SETTINGS_CONFIGMAP=backup-operator-settings

# --- Optional ---
# Leave LEADER_ELECTION_ID empty for a single local instance — election
# adds a Lease object and a few seconds of startup latency, neither of
# which we need when only one operator is running.
# LEADER_ELECTION_ID=
# DEFAULT_SCHEDULE=0 2 * * *
# RUN_TIMEOUT_SECONDS=3600
# TEMP_DIR=/tmp/backup-operator
# TEMP_DIR_SIZE=10Gi
# DEFAULT_RETENTION_DAYS=30
# DEFAULT_MIN_KEEP=3
